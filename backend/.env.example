ENVIRONMENT=dev
LOCAL_MODE=true
DB_MODE=mongodb
LOCAL_DB_PATH=./data/local_db.json
PORT=8000
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=sitfly

# Optional for real flight search in local mode
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Optional local Redis (Docker Compose)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SSL=false

# Optional: if someday you want to connect to Azure again
# COSMOS_ENDPOINT=
# COSMOS_KEY=
# COSMOS_DATABASE=flyseats2-db
